---
import Sidebar from '../components/Sidebar.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} | リサーチサイト（内部）</title>
  </head>
  <body>
    <div class="app">
      <aside class="sidebar">
        <Sidebar />
      </aside>
      <main class="main">
        <article class="prose">
          <slot />
        </article>
      </main>
    </div>
  </body>
</html>

<style is:global>
  :root {
    --bg: #fafaf8;
    --fg: #1a1a1a;
    --muted: #6b6b6b;
    --border: #e5e5e0;
    --link: #2847a1;
    --link-hover: #1a2f6b;
    --sidebar-bg: #f2f1ec;
    --font-sans: -apple-system, BlinkMacSystemFont, "Hiragino Kaku Gothic ProN", "Noto Sans JP", sans-serif;
    --font-mono: ui-monospace, SFMono-Regular, Menlo, monospace;
  }

  * {
    box-sizing: border-box;
  }

  html, body {
    margin: 0;
    padding: 0;
    background: var(--bg);
    color: var(--fg);
    font-family: var(--font-sans);
    font-size: 15px;
    line-height: 1.7;
  }

  .app {
    display: grid;
    grid-template-columns: 280px 1fr;
    min-height: 100vh;
  }

  .sidebar {
    background: var(--sidebar-bg);
    border-right: 1px solid var(--border);
    padding: 24px 20px;
    position: sticky;
    top: 0;
    max-height: 100vh;
    overflow-y: auto;
  }

  .main {
    padding: 48px 56px;
    max-width: 820px;
  }

  .prose a {
    color: var(--link);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose a:hover {
    color: var(--link-hover);
  }

  .prose h1 {
    font-size: 28px;
    margin: 0 0 24px;
    line-height: 1.3;
  }
  .prose h2 {
    font-size: 20px;
    margin: 40px 0 12px;
    line-height: 1.4;
    border-bottom: 1px solid var(--border);
    padding-bottom: 6px;
  }
  .prose h3 {
    font-size: 17px;
    margin: 28px 0 10px;
  }
  .prose p {
    margin: 12px 0;
  }
  .prose ul, .prose ol {
    margin: 12px 0;
    padding-left: 24px;
  }
  .prose li {
    margin: 4px 0;
  }
  .prose code {
    font-family: var(--font-mono);
    background: #ebeae5;
    padding: 2px 5px;
    border-radius: 3px;
    font-size: 0.9em;
  }
  .prose pre {
    background: #22221f;
    color: #e5e5e0;
    padding: 16px 20px;
    border-radius: 6px;
    overflow-x: auto;
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.5;
  }
  .prose pre code {
    background: transparent;
    padding: 0;
    color: inherit;
  }
  .prose blockquote {
    margin: 16px 0;
    padding: 4px 16px;
    border-left: 3px solid var(--border);
    color: var(--muted);
  }
  .prose table {
    border-collapse: collapse;
    margin: 16px 0;
    font-size: 14px;
  }
  .prose th, .prose td {
    border: 1px solid var(--border);
    padding: 6px 12px;
    text-align: left;
  }
  .prose th {
    background: #ebeae5;
  }

  @media (max-width: 800px) {
    .app {
      grid-template-columns: 1fr;
    }
    .sidebar {
      position: static;
      max-height: none;
      border-right: none;
      border-bottom: 1px solid var(--border);
    }
    .main {
      padding: 24px;
    }
  }
</style>
