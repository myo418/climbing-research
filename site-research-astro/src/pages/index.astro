---
import Layout from '../layouts/Layout.astro';
import { pages, getPageById } from '../lib/pages';
import { url } from '../lib/url';

// 主要テーマセクション（contents/ 直下の通常セクション）
// 既存 index.md の frontmatter から title/draft/order を引き、説明はここで持つ。
const SECTION_DESCRIPTIONS: Record<string, string> = {
  'basics': '種類・グレード・用語など、クライミングを理解する枠組み。',
  'climbers': '有名クライマー、当事者の声、自分自身のクライミング歴。',
  'climbing-and-injury': '怪我の種類と発生経緯の事実整理。動機・心理は扱わない。',
  'gear': 'シューズ・チョーク・メーカー。身体に最も近い道具から。',
  'places': 'クライミングジムと岩場。場が人をどう変えるか。',
  'references': '書籍・映画・SNS・YouTube。外部素材の入り口。',
  'research-methods': 'リサーチの進め方とインタビュー設計。',
  'training': 'クライマーのトレーニング。',
};

const topLevelDirs = new Set<string>();
const metaDirs = new Set<string>();
for (const p of pages) {
  if (p.id === 'index') continue;
  const top = p.id.split('/')[0];
  topLevelDirs.add(top);
  if (p.frontmatter?.section === 'meta') metaDirs.add(top);
}

const sections = [...topLevelDirs]
  .filter((d) => !metaDirs.has(d))
  .map((d) => {
    const idx = getPageById(d);
    const fm = idx?.frontmatter ?? {};
    return {
      id: d,
      title: (fm.title ?? d) as string,
      description: SECTION_DESCRIPTIONS[d] ?? '',
      draft: fm.draft === true,
      order: (fm.order ?? 99) as number,
    };
  })
  .sort((a, b) => a.order - b.order || a.title.localeCompare(b.title));

// 週次レポート（新しい順）
const weeklyEntries = pages
  .filter((p) => p.id.startsWith('weekly-report/') && p.id !== 'weekly-report')
  .map((p) => ({
    id: p.id,
    title: (p.frontmatter?.title ?? p.id) as string,
    date: p.id.replace('weekly-report/', ''),
  }))
  .sort((a, b) => b.date.localeCompare(a.date));

const latestWeekly = weeklyEntries[0];
const planExists = !!getPageById('plan');

const startDate = '2026-04-21';
---

<Layout title="ホーム">
  <div class="home">
    <header class="hero">
      <p class="kicker">武蔵野美術大学 / 後藤ゼミ / リサーチ（内部）</p>
      <h1 class="hero-title">
        <span class="line">クライミングをする</span>
        <span class="line">人々と、その怪我</span>
      </h1>
      <p class="lead">
        怪我のリスクがあるにもかかわらず、なぜ人はクライミングに打ち込むのか。<br />
        動機・身体観・リスクとの向き合い方を、素材を積み上げながら掘り下げる。
      </p>
    </header>

    <section class="questions">
      <h2 class="section-label">問い（仮）</h2>
      <ol class="qlist">
        <li>
          <span class="num">01</span>
          <span class="qtext">なぜ怪我のリスクを引き受けてまで、続けるのか。</span>
        </li>
        <li>
          <span class="num">02</span>
          <span class="qtext">クライマーにとって「怪我」はどういう意味を持つのか。<br />挫折なのか、通過儀礼なのか、身体との対話なのか。</span>
        </li>
        <li>
          <span class="num">03</span>
          <span class="qtext">続ける人と、やめる人。その境界はどこにあるのか。</span>
        </li>
      </ol>
    </section>

    <section class="themes">
      <h2 class="section-label">テーマ</h2>
      <ul class="theme-grid">
        {sections.map((s) => (
          <li class={`theme-card${s.draft ? ' draft' : ''}`}>
            {s.draft ? (
              <div class="card-inner">
                <div class="card-id">{s.id}</div>
                <div class="card-title">{s.title}</div>
                {s.description && <p class="card-desc">{s.description}</p>}
                <div class="card-status">未着手</div>
              </div>
            ) : (
              <a class="card-inner" href={url(`/${s.id}/`)}>
                <div class="card-id">{s.id}</div>
                <div class="card-title">{s.title}</div>
                {s.description && <p class="card-desc">{s.description}</p>}
                <div class="card-arrow">→</div>
              </a>
            )}
          </li>
        ))}
      </ul>
    </section>

    <section class="updates">
      <div class="updates-col">
        <h2 class="section-label">最近の更新</h2>
        {latestWeekly ? (
          <div class="weekly-latest">
            <div class="weekly-date">{latestWeekly.date}</div>
            <a class="weekly-link" href={url(`/${latestWeekly.id}/`)}>{latestWeekly.title}</a>
            {weeklyEntries.length > 1 && (
              <a class="weekly-all" href={url('/weekly-report/')}>過去の週次 ({weeklyEntries.length}件) →</a>
            )}
            {weeklyEntries.length === 1 && (
              <a class="weekly-all" href={url('/weekly-report/')}>週次レポート一覧 →</a>
            )}
          </div>
        ) : (
          <p class="muted">週次レポートはまだありません。</p>
        )}
      </div>

      <div class="updates-col">
        <h2 class="section-label">制作計画</h2>
        {planExists ? (
          <p>
            <a class="plan-link" href={url('/plan/')}>スケジュールと成果物の計画</a>
          </p>
        ) : (
          <p class="muted">未作成</p>
        )}
        <p class="meta">
          開始: {startDate} / 卒業までに、リサーチサイト・公開サイト・ゼミ発表の3つを形にする。
        </p>
      </div>
    </section>

    <footer class="site-foot">
      <p class="meta">
        このサイトは進行中のリサーチを後藤教授・ゼミメンバーに常時見える状態にするための作業場です。
        精査前の文章・仮説・読書メモを含みます。SEOからは除外されています（noindex）。
      </p>
    </footer>
  </div>
</Layout>

<style>
  .home {
    /* Layout の .prose ルール（max-width 820px の中）に収める */
    margin: -8px 0 0;
  }

  /* --- Hero --- */
  .hero {
    padding: 32px 0 48px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 48px;
  }
  .kicker {
    margin: 0 0 24px;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    font-family: var(--font-mono);
  }
  .hero-title {
    font-family: "YuMincho", "Hiragino Mincho ProN", "Noto Serif JP", serif;
    font-weight: 500;
    font-size: clamp(34px, 6vw, 56px);
    line-height: 1.25;
    margin: 0;
    border: none;
    padding: 0;
    letter-spacing: 0.02em;
  }
  .hero-title .line {
    display: block;
  }
  .hero-title .line + .line {
    margin-top: 0.1em;
  }
  .lead {
    margin: 28px 0 0;
    font-size: 16px;
    line-height: 1.85;
    color: var(--fg);
    max-width: 38em;
  }

  /* --- セクション共通 --- */
  .section-label {
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    font-family: var(--font-mono);
    font-weight: 600;
    margin: 0 0 20px;
    padding: 0;
    border: none;
  }

  /* --- 問い --- */
  .questions {
    margin-bottom: 64px;
  }
  .qlist {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 24px;
  }
  .qlist li {
    display: grid;
    grid-template-columns: 56px 1fr;
    align-items: baseline;
    gap: 4px;
    margin: 0;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--border);
  }
  .qlist li:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }
  .num {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--muted);
    letter-spacing: 0.05em;
  }
  .qtext {
    font-family: "YuMincho", "Hiragino Mincho ProN", "Noto Serif JP", serif;
    font-size: 19px;
    line-height: 1.7;
    color: var(--fg);
  }

  /* --- テーマグリッド --- */
  .themes {
    margin-bottom: 64px;
  }
  .theme-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }
  .theme-card {
    background: var(--bg);
    margin: 0;
  }
  .theme-card .card-inner {
    display: block;
    padding: 20px 22px 22px;
    text-decoration: none;
    color: inherit;
    height: 100%;
    position: relative;
    transition: background 0.15s ease;
  }
  a.card-inner:hover {
    background: #f2f1ec;
  }
  .card-id {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.04em;
    margin-bottom: 6px;
  }
  .card-title {
    font-family: "YuMincho", "Hiragino Mincho ProN", "Noto Serif JP", serif;
    font-size: 20px;
    line-height: 1.4;
    margin-bottom: 8px;
    color: var(--fg);
  }
  .card-desc {
    margin: 0;
    font-size: 13px;
    line-height: 1.7;
    color: var(--muted);
  }
  .card-arrow {
    position: absolute;
    right: 18px;
    bottom: 16px;
    font-size: 14px;
    color: var(--muted);
    transition: transform 0.15s ease, color 0.15s ease;
  }
  a.card-inner:hover .card-arrow {
    transform: translateX(3px);
    color: var(--link);
  }
  .theme-card.draft .card-title,
  .theme-card.draft .card-id {
    color: var(--muted);
  }
  .card-status {
    margin-top: 10px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
  }

  @media (max-width: 600px) {
    .theme-grid {
      grid-template-columns: 1fr;
    }
  }

  /* --- 更新 + 計画 --- */
  .updates {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    margin-bottom: 56px;
    padding-top: 32px;
    border-top: 1px solid var(--border);
  }
  @media (max-width: 600px) {
    .updates {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
  .weekly-latest {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .weekly-date {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--muted);
  }
  .weekly-link {
    font-family: "YuMincho", "Hiragino Mincho ProN", "Noto Serif JP", serif;
    font-size: 17px;
    color: var(--fg);
    text-decoration: none;
    line-height: 1.5;
  }
  .weekly-link:hover {
    color: var(--link);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .weekly-all {
    margin-top: 12px;
    font-size: 12px;
    color: var(--muted);
    text-decoration: none;
  }
  .weekly-all:hover {
    color: var(--link);
  }
  .plan-link {
    font-family: "YuMincho", "Hiragino Mincho ProN", "Noto Serif JP", serif;
    font-size: 17px;
    color: var(--fg);
    text-decoration: none;
  }
  .plan-link:hover {
    color: var(--link);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .meta {
    margin: 12px 0 0;
    font-size: 12px;
    color: var(--muted);
    line-height: 1.7;
  }
  .muted {
    color: var(--muted);
    font-size: 13px;
  }

  /* --- フッター --- */
  .site-foot {
    border-top: 1px solid var(--border);
    padding-top: 24px;
    margin-top: 16px;
  }
  .site-foot .meta {
    margin: 0;
    max-width: 44em;
  }
</style>
